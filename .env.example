# ── 자본 설정 ───────────────────────────────────────────
INITIAL_CAPITAL=1000          # 초기 자본 (USDC)

# ── LP 설정 ─────────────────────────────────────────────
LP_TOKEN=ETH                  # 대상 토큰 (ETH, BTC, SOL)
LP_FEE_TIER=0.3               # 수수료율 % (Byreal 기본 0.3%)
LP_RANGE_PCT=20               # 진입가 기준 ±% (예: 20 → ±20%)
LP_CAPITAL_RATIO=0.7          # 총 자본 중 LP 투입 비율 (0.7 = 70%)

# ── 리밸런싱 설정 ────────────────────────────────────────
REBALANCE_INTERVAL=300        # 업데이트 주기 (초, 기본 5분)
DELTA_THRESHOLD=0.05          # 델타 편차 임계값 (0.05 = 5%)

# ── 풀 볼륨 추정 (페이퍼 수수료 시뮬레이션용) ──────────────
# Byreal 전체 일 거래량 ~$25M, ETH/USDC 풀 ~30% 가정
ESTIMATED_POOL_DAILY_VOLUME=7500000
ESTIMATED_POOL_TVL=3000000

# ── 실시간 풀 데이터 (DeFi Llama) ───────────────────────
USE_LIVE_POOL_DATA=true        # DeFi Llama 실시간 데이터 사용 여부
POOL_ETH_USDC_SHARE=0.30       # Byreal 전체 TVL/수수료 중 ETH/USDC 풀 비중
POOL_STATS_REFRESH_INTERVAL=300  # 풀 데이터 갱신 주기 (초)

# ── 범위 리셋 설정 ────────────────────────────────────────
RANGE_RESET_ENABLED=true       # 범위 이탈 시 자동 재진입
LP_RESET_SLIPPAGE_PCT=0.15     # LP 입출금 슬리피지 % (실측: 0.1~0.3%)
SOLANA_TX_COST_USDC=0.003      # Solana 가스비 추정 (실측: ~$0.001~0.005)

# ── 리포트 설정 ──────────────────────────────────────────
LOG_INTERVAL=60               # 콘솔 리포트 주기 (초)

# ── 텔레그램 알림 (선택) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
