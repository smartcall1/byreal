# ============================================================
# Byreal 4-Pool 델타 헤지 봇 환경변수 예시
#
# 복사 후 사용:  cp .env.example .env
# 실행:          python main_multi.py
#
# ※ 풀 종목 · 레버리지 · 범위 · 자본은 .env가 아닌
#   pool_config.py 에서 직접 수정합니다.
# ============================================================

# ── 리밸런싱 ─────────────────────────────────────────────
REBALANCE_INTERVAL=300       # Perp 델타 리밸런싱 주기 (초, 기본 5분)
DELTA_THRESHOLD=0.05         # 델타 편차 5% 이상 시 리밸런싱

# ── 리포팅 ───────────────────────────────────────────────
LOG_INTERVAL=60              # 대시보드 출력 주기 (초, 기본 1분)

# ── 청산 버퍼 관리 ───────────────────────────────────────
LIQUIDATION_BUFFER_WARN=0.15       # 버퍼 15% 이하 → 경고 로그
LIQUIDATION_BUFFER_EMERGENCY=0.08  # 버퍼 8%  이하 → LP→마진 긴급 이전
MARGIN_TOPUP_RATIO=0.05            # 긴급 이전 시 LP 가치의 5% 이전

# ── 실시간 풀 데이터 ─────────────────────────────────────
USE_LIVE_POOL_DATA=true            # GeckoTerminal 실측 TVL·거래량 사용
POOL_STATS_REFRESH_INTERVAL=300    # 풀 데이터 캐시 갱신 주기 (초)

# ── LP 범위 리셋 비용 ────────────────────────────────────
RANGE_RESET_ENABLED=true
LP_RESET_SLIPPAGE_PCT=0.15   # 출금·입금 각 0.15% 슬리피지
SOLANA_TX_COST_USDC=0.003    # Solana 트랜잭션 수수료 추정 (USDC)

# ── 텔레그램 알림 (선택) ─────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# 아래는 단일풀 main.py 전용 변수입니다.
# main_multi.py (4개 풀) 실행 시에는 아래 값이 무시됩니다.
# 4개 풀 설정은 pool_config.py 에서 수정하세요.
# ============================================================
# INITIAL_CAPITAL=1000
# LP_TOKEN=ETH
# LP_FEE_TIER=0.3
# LP_RANGE_PCT=20
# LP_CAPITAL_RATIO=0.7
